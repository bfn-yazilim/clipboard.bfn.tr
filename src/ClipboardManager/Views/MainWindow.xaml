<Window x:Class="ClipboardManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ClipboardManager.ViewModels"
        Title="Clipboard &amp; Asset Manager"
        Height="600" Width="900"
        MinHeight="500" MinWidth="720"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Topmost="True"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Title bar -->
                <RowDefinition Height="Auto" /> <!-- Search bar -->
                <RowDefinition Height="*" />    <!-- Body -->
                <RowDefinition Height="Auto" /> <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ============ TITLE BAR ============ -->
            <Grid Grid.Row="0" Height="44" Background="{DynamicResource SurfaceBrush}" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="📋" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Clipboard &amp; Asset Manager"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="·  Ctrl+Shift+V ile açılır"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button Style="{StaticResource ModernButton}" Content="⚙" Width="34" Height="30"
                            ToolTip="Ayarlar" Click="Settings_Click" />
                    <Button Style="{StaticResource ModernButton}" Content="—" Width="34" Height="30"
                            ToolTip="Simge durumuna küçült" Click="Minimize_Click" />
                    <Button Style="{StaticResource ModernButton}" Content="✕" Width="34" Height="30"
                            ToolTip="Gizle (arka planda çalışmaya devam eder)" Click="Close_Click"
                            Background="Transparent" />
                </StackPanel>
            </Grid>

            <!-- ============ SEARCH BAR ============ -->
            <Grid Grid.Row="1" Margin="14,8,14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <TextBox x:Name="SearchBox"
                             Style="{StaticResource ModernTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=200}"
                             Tag="🔎  İçerik veya etiket ara..." />
                    <!-- Watermark -->
                    <TextBlock IsHitTestVisible="False" VerticalAlignment="Center" Margin="14,0,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{Binding ElementName=SearchBox, Path=Tag}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="⟲ Yenile"
                        Command="{Binding RefreshCommand}" Margin="8,0,0,0" />
            </Grid>

            <!-- ============ BODY ============ -->
            <Grid Grid.Row="2" Margin="14,0,14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ===== SIDEBAR (Groups) ===== -->
                <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <DockPanel LastChildFill="True">
                        <!-- Header -->
                        <Grid DockPanel.Dock="Top" Margin="12,12,12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="GRUPLAR"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="+"
                                    Width="22" Height="22" Padding="0"
                                    ToolTip="Yeni grup"
                                    Command="{Binding AddGroupCommand}" />
                        </Grid>

                        <!-- Group list -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Groups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:GroupViewModel}">
                                        <Button Style="{StaticResource GroupButton}"
                                                Margin="6,2"
                                                Tag="{Binding IsSelected}"
                                                Command="{Binding DataContext.SelectGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Icon}" FontSize="15" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- ===== ITEMS GRID (3-column WrapPanel) ===== -->
                <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <!-- Items -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <!-- 3 sütunlu yerlesim. Ekran genisledikce satirlar olusur. -->
                                        <UniformGrid Columns="3" HorizontalAlignment="Stretch" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ClipboardItemViewModel}">
                                        <Border Style="{StaticResource ItemCard}" Margin="5">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.PasteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}" />
                                            </Border.InputBindings>
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="📋 Yapıştır (auto)"
                                                              Command="{Binding DataContext.PasteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}" />
                                                    <MenuItem Header="📋 Sadece kopyala"
                                                              Command="{Binding DataContext.CopyToClipboardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}" />
                                                    <Separator />
                                                    <MenuItem Header="📁 Gruba ata..."
                                                              Command="{Binding DataContext.AssignGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}" />
                                                    <MenuItem Header="🏷️ Etiket ekle..."
                                                              Command="{Binding DataContext.AddTagCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}" />
                                                    <MenuItem Header="⭐ Favorilere ekle/çıkar"
                                                              Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}" />
                                                    <Separator />
                                                    <MenuItem Header="🗑️ Sil"
                                                              Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>

                                            <DockPanel LastChildFill="True">
                                                <!-- Header row -->
                                                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding TypeIcon}" FontSize="14" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Title}"
                                                               FontWeight="SemiBold"
                                                               FontSize="12"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               Margin="6,0,0,0" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="★"
                                                               Foreground="{DynamicResource FavoriteBrush}"
                                                               Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVis}}" />
                                                </Grid>

                                                <!-- Content preview -->
                                                <Border DockPanel.Dock="Top" Height="64" ClipToBounds="True">
                                                    <ContentControl>
                                                        <ContentControl.Style>
                                                            <Style TargetType="ContentControl">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="Image">
                                                                        <Setter Property="Content">
                                                                            <Setter.Value>
                                                                                <Image Source="{Binding ImageFilePath}"
                                                                                       Stretch="UniformToFill"
                                                                                       HorizontalAlignment="Center" />
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ContentControl.Style>
                                                        <TextBlock Text="{Binding Preview}"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="12"
                                                                   MaxHeight="64"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                                    </ContentControl>
                                                </Border>

                                                <!-- Footer -->
                                                <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                                    <TextBlock Text="{Binding TagsDisplay}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <DockPanel Margin="0,4,0,0">
                                                        <TextBlock DockPanel.Dock="Left"
                                                                   Text="{Binding CreatedDisplay}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                                        <TextBlock DockPanel.Dock="Right"
                                                                   Text="{Binding GroupName}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                                    </DockPanel>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Empty state -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,40">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Items.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="📭" FontSize="48" HorizontalAlignment="Center" />
                            <TextBlock Text="Henüz kopyalanan öğe yok"
                                       FontSize="13"
                                       Margin="0,12,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="Herhangi bir yerde CTRL+C yapın"
                                       FontSize="11"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ============ STATUS BAR ============ -->
            <Border Grid.Row="3" Height="28" Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12">
                <DockPanel LastChildFill="True" Margin="14,0">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Dinleniyor: ✔"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock DockPanel.Dock="Right"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center">
                        <Run Text="Öğe sayısı: " /><Run Text="{Binding Items.Count, Mode=OneWay}" />
                    </TextBlock>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
