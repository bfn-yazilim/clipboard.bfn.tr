<Window x:Class="ClipboardManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ClipboardManager.ViewModels"
        xmlns:dd="urn:gong-wpf-dragdrop"
        Title="Clipboard &amp; Asset Manager"
        Height="600" Width="900"
        MinHeight="500" MinWidth="720"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <!-- Value converters -->
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Title bar -->
                <RowDefinition Height="Auto" /> <!-- Search bar -->
                <RowDefinition Height="Auto" /> <!-- Tags bar -->
                <RowDefinition Height="*" />    <!-- Body -->
                <RowDefinition Height="Auto" /> <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ============ TITLE BAR ============ -->
            <Grid Grid.Row="0" Height="44" Background="{DynamicResource SurfaceBrush}" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="📋" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Clipboard &amp; Asset Manager"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="·  Ctrl+Shift+V ile açılır"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button Style="{StaticResource ModernButton}" Content="⚙" Width="34" Height="30"
                            ToolTip="Ayarlar" Click="Settings_Click" />
                    <Button Style="{StaticResource ModernButton}" Content="—" Width="34" Height="30"
                            ToolTip="Simge durumuna küçült" Click="Minimize_Click" />
                    <Button Style="{StaticResource ModernButton}" Content="✕" Width="34" Height="30"
                            ToolTip="Gizle (arka planda çalışmaya devam eder)" Click="Close_Click"
                            Background="Transparent" />
                </StackPanel>
            </Grid>

            <!-- ============ SEARCH BAR ============ -->
            <Grid Grid.Row="1" Margin="14,8,14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <TextBox x:Name="SearchBox"
                             Style="{StaticResource ModernTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=200}"
                             Tag="🔎  İçerik veya etiket ara..." />
                    <TextBlock IsHitTestVisible="False" VerticalAlignment="Center" Margin="14,0,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{Binding ElementName=SearchBox, Path=Tag}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="⟲ Yenile"
                        Command="{Binding RefreshCommand}" Margin="8,0,0,0" />
            </Grid>

            <!-- ============ TAGS BAR ============ -->
            <Grid Grid.Row="2" Margin="14,0,14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Tags}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TagViewModel}">
                                <Border Margin="0,0,6,0" CornerRadius="12" Padding="10,4"
                                        BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                                        Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <!-- Tek tiklama ile secimi degistir -->
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.SelectTagCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}" />
                                        <!-- Cift tiklama ile duzenleme moduna gec -->
                                        <MouseBinding MouseAction="LeftDoubleClick"
                                                      Command="{Binding DataContext.BeginEditTagCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}" />
                                    </Border.InputBindings>
                                    <Grid>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="Medium">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="White" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        
                                        <!-- Duzenleme Modu (TextBox) -->
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimaryBrush}"
                                                 VerticalAlignment="Center" Padding="0" MinWidth="40" MaxLength="20">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Enter" 
                                                            Command="{Binding DataContext.EndEditTagCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}" />
                                            </TextBox.InputBindings>
                                        </TextBox>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Column="1" Style="{StaticResource ModernButton}" Content="+" Width="28" Height="28" Padding="0"
                        ToolTip="Yeni Etiket" Command="{Binding AddTagCommand}" />
            </Grid>

            <!-- ============ BODY ============ -->
            <Grid Grid.Row="3" Margin="14,0,14,10">
                <!-- ===== ITEMS GRID (3-column WrapPanel) ===== -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <!-- Items -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                            <ItemsControl ItemsSource="{Binding Items}"
                                          dd:DragDrop.IsDragSource="True"
                                          dd:DragDrop.IsDropTarget="True"
                                          dd:DragDrop.DropHandler="{Binding}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <!-- 3 sütunlu yerlesim. Ekran genisledikce satirlar olusur. -->
                                        <UniformGrid Columns="3" HorizontalAlignment="Stretch" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ClipboardItemViewModel}">
                                        <Border Style="{StaticResource ItemCard}" Margin="5">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftDoubleClick"
                                                              Command="{Binding DataContext.PasteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}" />
                                            </Border.InputBindings>
                                            <Border.ContextMenu>
                                                <!-- Dinamik etiket menusu -->
                                                <ContextMenu>
                                                    <MenuItem Header="📋 Yapıştır (auto)"
                                                              Command="{Binding DataContext.PasteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}" />
                                                    <MenuItem Header="📋 Sadece kopyala"
                                                              Command="{Binding DataContext.CopyToClipboardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}" />
                                                    <Separator />
                                                    <MenuItem Header="🏷️ Etiketle / Etiketi Kaldır" 
                                                              ItemsSource="{Binding DataContext.Tags, RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <MenuItem.ItemContainerStyle>
                                                            <Style TargetType="MenuItem">
                                                                <Setter Property="Header" Value="{Binding DisplayName}" />
                                                                <Setter Property="Command" Value="{Binding DataContext.ToggleItemTagCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <!-- "Tümü" etiketini gizle -->
                                                                    <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </MenuItem.ItemContainerStyle>
                                                        <!-- Parametre olarak Item ve Secilen Tag'i aktarmamiz lazim, Converter veya MultiBinding gerekir, 
                                                             ancak MVVM'de daha basit bir cozum CommandParameter'e diziyi vermek -->
                                                        <MenuItem.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding DisplayName}" />
                                                            </DataTemplate>
                                                        </MenuItem.ItemTemplate>
                                                    </MenuItem>
                                                    <MenuItem Header="⭐ Favorilere ekle/çıkar"
                                                              Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}" />
                                                    <Separator />
                                                    <MenuItem Header="🗑️ Sil"
                                                              Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>

                                            <DockPanel LastChildFill="True">
                                                <!-- Header row -->
                                                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding TypeIcon}" FontSize="14" />
                                                    
                                                    <!-- Pin button -->
                                                    <Button Grid.Column="2" 
                                                            Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                            ToolTip="Üste Sabitle">
                                                        <TextBlock Text="📌" FontSize="14">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Opacity" Value="0.4" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                            <Setter Property="Opacity" Value="1.0" />
                                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Button>
                                                </Grid>

                                                <!-- Content preview -->
                                                <Border DockPanel.Dock="Top" MaxHeight="45" ClipToBounds="True">
                                                    <ContentControl>
                                                        <ContentControl.Style>
                                                            <Style TargetType="ContentControl">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="Image">
                                                                        <Setter Property="Content">
                                                                            <Setter.Value>
                                                                                <Image Source="{Binding ImageFilePath}"
                                                                                       Stretch="UniformToFill"
                                                                                       HorizontalAlignment="Center" />
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ContentControl.Style>
                                                        <TextBlock Text="{Binding Preview}"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="12"
                                                                   MaxHeight="45"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                                    </ContentControl>
                                                </Border>

                                                <!-- Footer -->
                                                <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                                    <!-- Burada kutuya atanan etiketleri gosteriyoruz -->
                                                    <TextBlock FontSize="10"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               TextTrimming="CharacterEllipsis">
                                                        <Run Text="🏷️ " />
                                                        <Run Text="{Binding TagsDisplay}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Empty state -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,40">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Items.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="📭" FontSize="48" HorizontalAlignment="Center" />
                            <TextBlock Text="Henüz kopyalanan öğe yok"
                                       FontSize="13"
                                       Margin="0,12,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="Herhangi bir yerde CTRL+C yapın"
                                       FontSize="11"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ============ STATUS BAR ============ -->
            <Border Grid.Row="4" Height="28" Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12">
                <DockPanel LastChildFill="True" Margin="14,0">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Dinleniyor: ✔"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock DockPanel.Dock="Right"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center">
                        <Run Text="Öğe sayısı: " /><Run Text="{Binding Items.Count, Mode=OneWay}" />
                    </TextBlock>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
